# Server
NODE_ENV=development
PORT=4000

# MongoDB
MONGO_URI=mongodb://localhost:27017/vkr_scada

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Max HTTP request body size (JSON / urlencoded payloads)
REQUEST_BODY_LIMIT=10mb

# PRO-tier bindings limit (0 = unlimited)
MAX_PRO_BINDINGS=0

# Default ADMIN provisioning (seed script)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change_me_to_a_long_password_min_16_chars

# Edge lifecycle credential generation
EDGE_PERSISTENT_SECRET_BYTES=48
